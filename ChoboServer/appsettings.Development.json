{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "{Timestamp:O} [{Level:u3}] {SourceContext} {Message:lj} {Properties}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "C:/tmp/Chobo/logs/chobo-dev-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "{Timestamp:O} [{Level:u3}] {SourceContext} {Message:lj} {Properties}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Chobo": {
    "DataDirectory": "C:/tmp/Chobo/data-dev",
    "EncryptionKeyBase64": "MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=",
    "Init": {
      "AdminUser": "admin",
      "AccessToken": "dev-static-access-token"
    },
    "DataRetention": {
      "Interval": "01:00:00",
      "LogsBefore": null,
      "AuditsBefore": null
    },
    "SqliteSelfBackup": {
      "Enabled": false,
      "Directory": null,
      "BackupInterval": "1.00:00:00",
      "PollInterval": "00:05:00"
    },
    "BackupRestore": {
      "MaxDop": 3,
      "QueueCapacity": 100,
      "MaxActiveQueueItems": 1000,
      "SchedulerInterval": "00:01:00",
      "SchedulerMissedRunGracePeriod": "00:05:00",
      "PollInterval": "00:00:06",
      "ManifestCheckpointShardInterval": 20,
      "ManifestWriteTimeout": "00:01:30",
      "TransientShardMaxRetries": 3,
      "TransientShardRetryDelay": "00:01:00"
    },
    "RetentionManagement": {
      "Interval": "01:00:00",
      "MaxDop": 2
    },
    "BackupsGarbageCollector": {
      "Interval": "01:00:00",
      "MaxDop": 2
    },
    "Web": {
      "IsGuiEnabled": true,
      "GuiPort": null
    },
    "EndpointRewrites": {
