{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.SQLite"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "SQLite",
        "Args": {
          "sqliteDbPath": "data/chobo.db",
          "tableName": "ApplicationLogEntries",
          "restrictedToMinimumLevel": "Information",
          "storeTimestampInUtc": true,
          "batchSize": 100,
          "maxDatabaseSize": 1024,
          "rollOver": false
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Chobo": {
    "DataDirectory": "data",
    "EncryptionKeyBase64": null,
    "Init": {
      "AdminUser": null,
      "AccessToken": null
    },
    "DataRetention": {
      "Interval": "01:00:00",
      "LogsBefore": null,
      "AuditsBefore": null
    }
  }
}
